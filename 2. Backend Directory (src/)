require('dotenv').config();
const express = require('express');
const http = require('http');
const mongoose = require('mongoose');
const { Server } = require('socket.io');
const path = require('path');

const app = express();
const server = http.createServer(app);
const io = new Server(server, { cors: { origin: "*" } });

app.use(express.json());
app.use(express.static(path.join(__dirname, '../public')));

// Atlas Connection
mongoose.connect(process.env.MONGODB_URI)
    .then(() => console.log('>>> OG PUNKZ ATLAS LINKED'))
    .catch(err => console.error('DB Link Failed:', err));

// Routes & Socket logic would be imported here
// (Refer to previous logic for /api/plant and /api/harvest)

const PORT = process.env.PORT || 3000;
server.listen(PORT, () => console.log(`Engine online at port ${PORT}`));
